{
  "moduleFileExtensions": ["js", "json", "ts", "mjs"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)sx?$": "ts-jest",
    "^.+\\.mjs$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(better-auth|@thallesp)/)"
  ]
}
