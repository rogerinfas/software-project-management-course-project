#!/usr/bin/env sh
set -e

ROOT="$(git rev-parse --show-toplevel)"
FILES="$(git diff --cached --name-only --diff-filter=ACM | rg '^prototype/(src/.+\.(ts|tsx)|[^/]+\.(ts|tsx))$' | sed "s|^prototype/||" || true)"
if [ -z "$FILES" ]; then
  exit 0
fi

cd "$ROOT/prototype"
echo "$FILES" | xargs pnpm exec eslint --max-warnings 0
